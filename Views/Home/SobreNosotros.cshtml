@{
    ViewData["Title"] = "Sobre Nosotros";
}

@section Styles {
    <style>
        body { background-color: #121212; color: #ffffff; font-family: 'Inter', sans-serif; }
        
        .fw-900 { font-weight: 800; }
        .text-danger { color: #eb0a1e !important; }
        .text-muted { color: #aaaaaa !important; }

        /* HERO SECTION */
        .hero-nosotros {
            position: relative;
            height: 50vh;
            min-height: 400px;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/img/nosotros-bg.jpg') center/cover no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .hero-content { position: relative; z-index: 2; padding-top: 60px; }

        .linea-acento {
            width: 60px;
            height: 4px;
            background-color: #eb0a1e;
            margin: 15px auto;
        }

        /* SECCIÓN HISTORIA */
        .historia-img {
            border-left: 5px solid #eb0a1e;
            padding-left: 0;
            position: relative;
        }

        .img-overlap {
            width: 100%;
            height: 450px;
            object-fit: cover;
            filter: grayscale(0.3);
        }

        /* STATS (Contadores) */
        .stats-section {
            background-color: #1e1e1e;
            padding: 60px 0;
            border-top: 1px solid #333;
            border-bottom: 1px solid #333;
        }

        .stat-item h2 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 0;
            color: #eb0a1e;
        }

        .stat-item p {
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #fff;
        }

        /* VALORES */
        .valor-card {
            background-color: #1a1a1a;
            border: 1px solid #333;
            padding: 30px;
            transition: 0.3s;
            height: 100%;
        }

        .valor-card:hover {
            border-color: #eb0a1e;
            transform: translateY(-5px);
        }

        .valor-icon {
            font-size: 2.5rem;
            color: #eb0a1e;
            margin-bottom: 20px;
        }
    </style>
}

<section class="hero-nosotros">
    <div class="hero-content">
        <p class="text-danger fw-bold text-uppercase mb-0" style="letter-spacing: 3px;">Nuestra Trayectoria</p>
        <h1 class="text-uppercase fw-900 display-4">Jonel Automotores</h1>
        <div class="linea-acento"></div>
        <p class="lead text-light">Más de 15 años transformando el mercado automotriz en San Luis.</p>
    </div>
</section>

<section class="py-5 my-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 historia-img">
                <img src="/img/cars/showroom.jpg" alt="Showroom Jonel" class="img-overlap shadow-lg">
            </div>
            <div class="col-lg-6">
                <h6 class="text-danger fw-bold text-uppercase">Quiénes Somos</h6>
                <h2 class="display-5 fw-800 text-uppercase mb-4">Pasión por la excelencia sobre ruedas</h2>
                <p class="text-muted fs-5">
                    En <strong>Jonel Automotores</strong>, no solo vendemos autos; entregamos soluciones de movilidad con el respaldo y la confianza que nuestros clientes merecen. 
                </p>
                <p class="text-muted">
                    Nacimos con la visión de profesionalizar la compra-venta de vehículos en la región, estableciendo estándares de calidad rigurosos en cada unidad de nuestro stock. Hoy somos referentes gracias a nuestra transparencia y atención personalizada.
                </p>
                <div class="mt-4">
                    <a asp-controller="Vehiculos" asp-action="Index" class="btn btn-outline-danger px-4 py-2 fw-bold text-uppercase" style="border-radius:0;">Ver Inventario</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="stats-section my-5">
    <div class="container text-center">
        <div class="row g-4">
            <div class="col-md-3 stat-item">
                <h2>15+</h2>
                <p>Años de Experiencia</p>
            </div>
            <div class="col-md-3 stat-item">
                <h2>2k+</h2>
                <p>Ventas Concluidas</p>
            </div>
            <div class="col-md-3 stat-item">
                <h2>100%</h2>
                <p>Garantía de Origen</p>
            </div>
            <div class="col-md-3 stat-item">
                <h2>24/7</h2>
                <p>Asesoría Post-Venta</p>
            </div>
        </div>
    </div>
</section>

<section class="container py-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-800 text-uppercase">Pilares Jonel</h2>
        <div class="linea-acento"></div>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="valor-card text-center">
                <div class="valor-icon"><i class="bi bi-shield-check"></i></div>
                <h4 class="fw-bold">Seguridad Legal</h4>
                <p class="text-muted">Verificación técnica y documental exhaustiva en cada unidad ingresada a nuestro stock.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="valor-card text-center">
                <div class="valor-icon"><i class="bi bi-star"></i></div>
                <h4 class="fw-bold">Calidad Premium</h4>
                <p class="text-muted">Seleccionamos solo los mejores vehículos, garantizando estado impecable y bajo kilometraje.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="valor-card text-center">
                <div class="valor-icon"><i class="bi bi-people"></i></div>
                <h4 class="fw-bold">Confianza</h4>
                <p class="text-muted">Acompañamos a nuestros clientes en todo el proceso de financiación y transferencia.</p>
            </div>
        </div>
    </div>
</section>