
@{
    ViewData["Title"] = "Contacto";
}

@section Styles {
    <style>
        /* Ajuste para que el Hero empiece desde arriba y el Navbar sea transparente sobre él */
        body { background-color: #121212; color: #ffffff; font-family: 'Inter', sans-serif; }
        
        .fw-900 { font-weight: 800; } /* Ajustado a 800 que es lo que cargaste en Inter */
        .text-danger { color: #eb0a1e !important; }
        .text-muted { color: #aaaaaa !important; }
        
        /* HERO SECTION - Ajustado para que encaje bajo tu headerNav */
        .hero-contacto {
            position: relative;
            min-height: 300px;
            background: url('/img/contacto-bg.jpg') center/cover no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            margin-top: 5rem;
        }

        .hero-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, rgba(18,18,18,0.4), rgba(18,18,18,1));
            z-index: 1;
        }

        .hero-content { position: relative; z-index: 2; padding-top: 80px; }

        .linea-acento {
            width: 60px;
            height: 4px;
            background-color: #eb0a1e;
            margin: 15px auto;
        }

        /* Contenedores de Formulario estilo Jonel */
        .contact-card {
            background-color: #1e1e1e;
            border: 1px solid #333;
            border-radius: 0;
            padding: 40px;
        }

        .form-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 800;
            letter-spacing: 1.5px;
            color: #ffffff;
            margin-bottom: 8px;
        }

        .form-control, .form-select {
            background-color: #ffffff;
            border: 1px solid #444;
            color: #1e1e1e !important;
            border-radius: 0;
            padding: 12px;
            font-size: 0.9rem;
        }

        .form-control:focus, .form-select:focus {
            background-color: #e9e9e9;
            border-color: #eb0a1e;
            box-shadow: none;
        }

        /* Botón de alto impacto */
        .btn-enviar {
            background-color: #eb0a1e;
            color: #ffffff;
            border: 2px solid #eb0a1e;
            border-radius: 0;
            font-weight: 800;
            text-transform: uppercase;
            padding: 15px;
            letter-spacing: 2px;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-enviar:hover {
            background-color: transparent;
            color: #eb0a1e;
        }

        /* Info boxes laterales */
        .info-box {
            background-color: #1e1e1e;
            border-right: 4px solid #eb0a1e;
            padding: 25px;
            margin-bottom: 20px;
        }

        .info-box h5 { color: #ffffff; font-weight: 800; letter-spacing: 1px; }

        .icon-circle {
            font-size: 1.5rem;
            color: #eb0a1e;
            margin-bottom: 10px;
        }

        .map-container {
            width: 100%;
            height: 320px;
            filter: grayscale(1) invert(0.9) contrast(1.2); 
            border: 1px solid #333;
        }
    </style>
}

@model Concesionario.Models.ContactoModel

<div class="hero-contacto">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="text-danger fw-bold text-uppercase mb-0" style="letter-spacing: 3px;">Atención Personalizada</p>
        <h1 class="text-uppercase fw-900 display-4">Contacto</h1>
        <div class="linea-acento"></div>
        <p class="text-muted">Estamos para asesorarte en tu próxima inversión.</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5">
        <div class="col-lg-7">
            <div class="contact-card shadow-lg">
                <h3 class="fw-900 text-uppercase mb-4">Envianos tu consulta</h3>
                @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Mensaje"]
                        </div>
                    }
                <div asp-validation-summary="All" class="text-danger"></div>
                <form method="post" asp-action="EnviarContacto" asp-controller="Home">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Nombre y Apellido</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre completo">
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">WhatsApp</label>
                            <input asp-for="Telefono" class="form-control" placeholder="+54 266 400-0000">
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Correo Electrónico</label>
                            <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Interés</label>
                            <select asp-for="Interes" class="form-select">
                                <option value="">Seleccionar interés</option>
                                <option>Compra de Vehículo</option>
                                <option>Venta / Permuta</option>
                                <option>Financiación</option>
                            </select>
                            <span asp-validation-for="Interes" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Modelo de Interés</label>
                            <input asp-for="Modelo" class="form-control" placeholder="Ej: Toyota Hilux">
                        </div>

                        <div class="col-12">
                            <label class="form-label">Mensaje</label>
                            <textarea asp-for="Mensaje" class="form-control" rows="4" placeholder="¿En qué podemos ayudarte?"></textarea>
                            <span asp-validation-for="Mensaje" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn-enviar">
                                ENVIAR AHORA <i class="bi bi-chevron-right ms-2"></i>
                            </button>
                        </div>

                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="info-box shadow-sm">
                <div class="icon-circle"><i class="bi bi-geo-alt-fill"></i></div>
                <h5 class="text-uppercase">Nuestra Agencia</h5>
                <p class="text-muted m-0">Av. España 1234, San Luis, Argentina</p>
            </div>

            <div class="info-box shadow-sm">
                <div class="icon-circle"><i class="bi bi-whatsapp"></i></div>
                <h5 class="text-uppercase">Ventas WhatsApp</h5>
                <p class="text-muted m-0">+54 266 400-0000</p>
            </div>

            <div class="info-box shadow-sm">
                <div class="icon-circle"><i class="bi bi-clock"></i></div>
                <h5 class="text-uppercase">Horarios</h5>
                <p class="text-muted m-0">Lun a Vie: 09:00 a 20:00hs / Sab: 09:00 a 13:00hs</p>
            </div>

            <iframe class="map-container shadow-sm" 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3334.96685170504!2d-66.34668422344785!3d-33.29353018949473!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95d43945866a7b49%3A0x76f1cb4e49d53815!2sAv.%20Espa%C3%B1a%201234%2C%20D5700BWV%20San%20Luis!5e0!3m2!1ses-419!2sar!4v1775861750676!5m2!1ses-419!2sar" 
                width="100%" 
                height="400" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy">
            </iframe>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}