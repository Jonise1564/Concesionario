
@* Views/Home/Index.cshtml *@
@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true"/>
}

<section class="py-5 bg-white">
    <div class="container text-center">
        <h2 class="fw-light">Bienvenidos a <span class="fw-bold">JONEL AUTOS</span></h2>
        <hr style="width: 50px; border: 2px solid #eb0a1e; margin: 20px auto;">
    </div>
</section>

<div class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="mb-1">EL NUEVO VEHÍCULO | DISPONIBLE HOY</p>
        <h1>TU PRÓXIMO AUTO</h1>
        <p>Conocé la nueva experiencia de conducción premium y accedé a planes de financiación exclusivos.</p>
        <a href="/Vehiculos" class="btn-toyota">CONOCÉ MÁS</a>
    </div>
</div>

<div class="model-bar">
    <div class="container d-flex justify-content-around">
        <a href="#" class="model-item text-uppercase small">Modelos</a>
        <a href="#" class="model-item text-uppercase small">Comprá</a>
        <a href="#" class="model-item text-uppercase small">Alquilá</a>
        <a href="#" class="model-item text-uppercase small">Mi Vehículo</a>
        <a href="#" class="model-item text-uppercase small">Descubrí</a>
        <a href="#" class="model-item text-uppercase small">Contactanos</a>
    </div>
</div>

