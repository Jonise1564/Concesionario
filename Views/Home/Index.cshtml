@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true"/>
}

<!-- HERO -->
<div class="hero">

    <div class="hero-overlay"></div>

    <div class="hero-content text-center">
        <p class="subtitulo">TU CONCESIONARIO DE CONFIANZA</p>
        <h1>Tu Próximo Auto Te Espera</h1>
        <p class="descripcion">
            Conocé la mejor selección de vehículos y accedé a financiación exclusiva.
        </p>

        <a asp-controller="Vehiculos" asp-action="Index" class="btn-hero">
            Explorar vehículos
        </a>
    </div>

</div>

<!-- SECCIÓN SIMPLE -->
<section class="bienvenida">
    <div class="container text-center">

        <h2 class="titulo-bienvenida">
            Bienvenidos a <span>Jonel Automotores</span>
        </h2>

        <div class="linea"></div>

        <p class="texto-bienvenida">
            Encontrá los mejores vehículos con financiación accesible y atención personalizada.
        </p>

    </div>
</section>