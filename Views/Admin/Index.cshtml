@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // DATA HARDCODEADA (Puedes ampliarla según necesites)
        const vehiculosData = {
            "Toyota": {
                "Corolla Cross": ["XLI 2.0", "XEI 2.0", "SEG 2.0", "SEG Hybrid"],
                "Hilux": ["SR 2.8", "SRV 2.8", "SRX 2.8", "GR-Sport"],
                "Etios": ["X 1.5", "XLS 1.5"]
            },
            "Fiat": {
                "Cronos": ["Drive 1.3", "Stile 1.3", "Precision 1.3 AT"],
                "Toro": ["Freedom 2.0", "Volcano 2.0", "Ultra 2.0"],
                "Pulse": ["Drive 1.3", "Impetus 1.0T"]
            },
            "Volkswagen": {
                "Amarok": ["Trendline", "Comfortline", "Highline", "Extreme V6"],
                "Taos": ["Comfortline", "Highline"],
                "Gol": ["Trend", "Last Edition"]
            }
        };

        const token = localStorage.getItem('jonel_token');
        const myModal = new bootstrap.Modal(document.getElementById('modalVehiculo'));
        const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, background: '#111', color: '#fff' });

        document.addEventListener("DOMContentLoaded", () => {
            if (!token) window.location.href = '/Home/Acceso';
            cargarMarcas();
            listar();
        });

        // Lógica de Selects Dependientes
        function cargarMarcas() {
            const select = document.getElementById('vMarca');
            Object.keys(vehiculosData).forEach(m => {
                select.innerHTML += `<option value="${m}">${m}</option>`;
            });
        }

        function cargarModelos() {
            const marca = document.getElementById('vMarca').value;
            const selectMod = document.getElementById('vModelo');
            const selectVer = document.getElementById('vVersion');
            
            selectMod.innerHTML = '<option value="">Seleccione modelo...</option>';
            selectVer.innerHTML = '<option value="">Seleccione modelo...</option>';
            selectVer.disabled = true;

            if (marca) {
                selectMod.disabled = false;
                Object.keys(vehiculosData[marca]).forEach(m => {
                    selectMod.innerHTML += `<option value="${m}">${m}</option>`;
                });
            } else {
                selectMod.disabled = true;
            }
        }

        function cargarVersiones() {
            const marca = document.getElementById('vMarca').value;
            const modelo = document.getElementById('vModelo').value;
            const selectVer = document.getElementById('vVersion');
            
            selectVer.innerHTML = '<option value="">Seleccione...</option>';
            
            if (modelo) {
                selectVer.disabled = false;
                vehiculosData[marca][modelo].forEach(v => {
                    selectVer.innerHTML += `<option value="${v}">${v}</option>`;
                });
            } else {
                selectVer.disabled = true;
            }
        }

        function previewImagen(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }

        async function listar() {
            try {
                const resp = await fetch('/Admin/GetVehiculos', { headers: { 'Authorization': `Bearer ${token}` } });
                const data = await resp.json();
                document.getElementById('tablaCuerpo').innerHTML = data.map(v => `
                    <tr class="align-middle">
                        <td class="fw-bold text-white">${v.marca}</td>
                        <td class="text-white">${v.modelo} <br><small class="text-muted">${v.version || ''}</small></td>
                        <td class="text-white">${v.anio}</td>
                        <td class="text-danger fw-bold">$ ${v.precio.toLocaleString()}</td>
                        <td class="text-white">${v.stock}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-light me-2" onclick='editar(${JSON.stringify(v)})'><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="eliminar(${v.id})"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>`).join('');
            } catch (err) { console.error(err); }
        }

        function abrirModal() {
            document.getElementById('formVehiculo').reset();
            document.getElementById('vId').value = "0";
            document.getElementById('vModelo').disabled = true;
            document.getElementById('vVersion').disabled = true;
            document.getElementById('imgPreview').src = "";
            myModal.show();
        }

        async function editar(v) {
            abrirModal();
            document.getElementById('modalTitulo').innerText = "MODIFICAR VEHÍCULO";
            document.getElementById('vId').value = v.id;
            document.getElementById('vMarca').value = v.marca;
            cargarModelos();
            document.getElementById('vModelo').value = v.modelo;
            cargarVersiones();
            document.getElementById('vVersion').value = v.version;
            document.getElementById('vAnio').value = v.anio;
            document.getElementById('vKilometros').value = v.kilometros;
            document.getElementById('vPrecio').value = v.precio;
            document.getElementById('vStock').value = v.stock;
            document.getElementById('vCombustible').value = v.combustible;
            document.getElementById('vTransmision').value = v.transmision;
            document.getElementById('imgPreview').src = v.imagenUrl || "";
            myModal.show();
        }

        function validarYGuardar() {
            const form = document.getElementById('formVehiculo');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }
            guardar();
        }

        async function guardar() {
            const formData = new FormData();
            formData.append("Id", document.getElementById('vId').value);
            formData.append("Marca", document.getElementById('vMarca').value);
            formData.append("Modelo", document.getElementById('vModelo').value);
            formData.append("Version", document.getElementById('vVersion').value);
            formData.append("Anio", document.getElementById('vAnio').value);
            formData.append("Kilometros", document.getElementById('vKilometros').value);
            formData.append("Precio", document.getElementById('vPrecio').value);
            formData.append("Stock", document.getElementById('vStock').value);
            formData.append("Combustible", document.getElementById('vCombustible').value);
            formData.append("Transmision", document.getElementById('vTransmision').value);

            const file = document.getElementById('vFile').files[0];
            if (file) formData.append("File", file);

            const resp = await fetch('/Admin/Guardar', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });

            if (resp.ok) {
                myModal.hide();
                listar();
                Toast.fire({ icon: 'success', title: 'Guardado correctamente' });
            }
        }

        async function eliminar(id) {
            Swal.fire({ title: '¿Eliminar unidad?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#dc3545', background: '#111', color: '#fff' }).then(async res => {
                if (res.isConfirmed) {
                    const resp = await fetch(`/Admin/Eliminar?id=${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
                    if(resp.ok) { listar(); Toast.fire({ icon: 'success', title: 'Eliminado' }); }
                }
            });
        }
    </script>
}