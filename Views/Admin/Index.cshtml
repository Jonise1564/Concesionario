@section Scripts {
    <script>
        const token = localStorage.getItem('jonel_token');
        const myModal = new bootstrap.Modal(document.getElementById('modalVehiculo'));

        document.addEventListener("DOMContentLoaded", () => {
            if (!token) window.location.href = '/Home/Acceso';
            listar();
        });

        async function listar() {
            try {
                const resp = await fetch('/Admin/GetVehiculos', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await resp.json();
                document.getElementById('tablaCuerpo').innerHTML = data.map(v => `
                    <tr class="align-middle">
                        <td class="fw-bold text-white">${v.marca}</td>
                        <td class="text-white">${v.modelo} <br><small class="text-muted">${v.version || ''}</small></td>
                        <td class="text-white">${v.anio}</td>
                        <td class="text-danger fw-bold">$ ${v.precio.toLocaleString()}</td>
                        <td class="text-white">${v.stock}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-light me-2" onclick='editar(${JSON.stringify(v)})'>
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="eliminar(${v.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (err) { console.error("Error al listar:", err); }
        }

        function abrirModal() {
            document.getElementById('formVehiculo').reset();
            document.getElementById('vId').value = "0";
            myModal.show();
        }

        async function guardar() {
            const model = {
                id: parseInt(document.getElementById('vId').value),
                marca: document.getElementById('vMarca').value,
                modelo: document.getElementById('vModelo').value,
                version: document.getElementById('vVersion').value,
                anio: parseInt(document.getElementById('vAnio').value),
                kilometros: parseInt(document.getElementById('vKilometros').value),
                precio: parseFloat(document.getElementById('vPrecio').value),
                stock: parseInt(document.getElementById('vStock').value),
                combustible: document.getElementById('vCombustible').value,
                transmision: document.getElementById('vTransmision').value,
                categoriaId: parseInt(document.getElementById('vCategoriaId').value),
                imagenUrl: document.getElementById('vImagenUrl').value || "default.jpg"
            };

            const response = await fetch('/Admin/Guardar', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json', 
                    'Authorization': `Bearer ${token}` 
                },
                body: JSON.stringify(model)
            });

            if (response.ok) {
                myModal.hide();
                listar();
            } else {
                alert("Error al guardar los datos.");
            }
        }

        function editar(v) {
            document.getElementById('vId').value = v.id;
            document.getElementById('vMarca').value = v.marca;
            document.getElementById('vModelo').value = v.modelo;
            document.getElementById('vVersion').value = v.version;
            document.getElementById('vAnio').value = v.anio;
            document.getElementById('vKilometros').value = v.kilometros;
            document.getElementById('vPrecio').value = v.precio;
            document.getElementById('vStock').value = v.stock;
            document.getElementById('vCombustible').value = v.combustible;
            document.getElementById('vTransmision').value = v.transmision;
            document.getElementById('vCategoriaId').value = v.categoriaId;
            document.getElementById('vImagenUrl').value = v.imagenUrl;
            myModal.show();
        }

        async function eliminar(id) {
            if (confirm("¿Eliminar este vehículo?")) {
                const resp = await fetch(`/Admin/Eliminar?id=${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(resp.ok) listar();
            }
        }
    </script>
