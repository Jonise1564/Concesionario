@* @{
    ViewData["Title"] = "Panel de Control";
}

<style>
    /* Estructura Principal */
    .admin-container {
        display: flex;
        min-height: 100vh;
        background-color: #000;
        /* Subimos a 100px para que el Navbar del layout no tape el título */
        padding-top: 100px; 
        position: relative;
    }

    /* Barra Lateral */
    .sidebar {
        width: 250px;
        background-color: #0b0b0b;
        border-right: 1px solid #222;
        padding: 20px;
        position: fixed;
        /* Debe coincidir con el padding-top del contenedor */
        top: 100px; 
        left: 0;
        bottom: 0;
        z-index: 999;
    }

    /* Área de Contenido */
    .main-content {
        margin-left: 250px; 
        width: calc(100% - 250px);
        padding: 30px;
    }

    .nav-admin-link {
        display: flex;
        align-items: center;
        padding: 12px 15px;
        color: #888;
        text-decoration: none;
        border-radius: 8px;
        margin-bottom: 10px;
        transition: 0.3s;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .nav-admin-link:hover, .nav-admin-link.active {
        background-color: #dc3545;
        color: white;
    }

    .nav-admin-link i {
        margin-right: 10px;
        font-size: 1.1rem;
    }

    /* Ajustes de Tabla */
    .table-dark {
        background-color: #0b0b0b !important;
    }

    /* Forzar que el Navbar del Layout esté por encima de la sidebar */
    .fixed-top {
        z-index: 1030 !important;
    }
</style>

<div class="admin-container">
    <aside class="sidebar">
        <p class="text-muted small fw-bold mb-4 px-2">MENÚ ADMINISTRADOR</p>
        <nav>
            <a href="#" class="nav-admin-link active">
                <i class="bi bi-car-front"></i> Vehículos
            </a>
            <a href="#" class="nav-admin-link">
                <i class="bi bi-people"></i> Usuarios
            </a>
            <a href="#" class="nav-admin-link">
                <i class="bi bi-envelope"></i> Mensajes
            </a>
            <a href="#" class="nav-admin-link">
                <i class="bi bi-gear"></i> Configuración
            </a>
            <hr class="border-secondary">
            <a href="/" class="nav-admin-link text-info">
                <i class="bi bi-arrow-left-circle"></i> Volver a la Web
            </a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-800 text-uppercase text-white">Gestión de <span class="text-danger">Stock</span></h2>
                <button class="btn btn-danger btn-sm px-4 fw-bold" onclick="abrirModal()">
                    <i class="bi bi-plus-lg"></i> NUEVO INGRESO
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-dark table-hover border-secondary">
                    <thead class="text-muted small">
                        <tr>
                            <th>MARCA</th>
                            <th>MODELO</th>
                            <th>AÑO</th>
                            <th>PRECIO</th>
                            <th>ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody id="tablaCuerpo">
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="modalVehiculo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title fw-bold text-white">DATOS DEL VEHÍCULO</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formVehiculo">
                    <input type="hidden" id="vId" value="0">
                    <div class="mb-3">
                        <label class="form-label small text-muted">MARCA</label>
                        <input type="text" id="vMarca" class="form-control bg-black border-secondary text-white" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">MODELO</label>
                        <input type="text" id="vModelo" class="form-control bg-black border-secondary text-white" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small text-muted">AÑO</label>
                            <input type="number" id="vAnio" class="form-control bg-black border-secondary text-white" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small text-muted">PRECIO</label>
                            <input type="number" id="vPrecio" class="form-control bg-black border-secondary text-white" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light btn-sm" data-bs-dismiss="modal">CANCELAR</button>
                <button type="button" class="btn btn-danger btn-sm px-4" onclick="guardar()">GUARDAR</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const token = localStorage.getItem('jonel_token');
        const myModal = new bootstrap.Modal(document.getElementById('modalVehiculo'));

        document.addEventListener("DOMContentLoaded", () => {
            if (!token) window.location.href = '/Home/Acceso';
            listar();
        });

        async function listar() {
            try {
                const resp = await fetch('/Admin/GetVehiculos', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await resp.json();
                document.getElementById('tablaCuerpo').innerHTML = data.map(v => `
                    <tr class="align-middle">
                        <td class="fw-bold text-white">${v.marca}</td>
                        <td class="text-white">${v.modelo}</td>
                        <td class="text-white">${v.anio}</td>
                        <td class="text-danger fw-bold">$ ${v.precio.toLocaleString()}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-light me-2" onclick="editar(${v.id}, '${v.marca}', '${v.modelo}', ${v.anio}, ${v.precio})">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="eliminar(${v.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (err) { console.error("Error al listar:", err); }
        }

        function abrirModal() {
            document.getElementById('formVehiculo').reset();
            document.getElementById('vId').value = "0";
            myModal.show();
        }

        async function guardar() {
            // Recopilamos datos asegurando tipos correctos
            const model = {
                id: parseInt(document.getElementById('vId').value),
                marca: document.getElementById('vMarca').value,
                modelo: document.getElementById('vModelo').value,
                anio: parseInt(document.getElementById('vAnio').value),
                precio: parseFloat(document.getElementById('vPrecio').value),
                // Agregamos campos que la BD suele pedir para no dar error 400
                imagenUrl: "default.jpg", 
                disponible: true
            };

            if(!model.marca || !model.modelo) {
                alert("Marca y Modelo son obligatorios");
                return;
            }

            const response = await fetch('/Admin/Guardar', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json', 
                    'Authorization': `Bearer ${token}` 
                },
                body: JSON.stringify(model)
            });

            if (response.ok) {
                myModal.hide();
                listar();
            } else {
                const error = await response.text();
                alert("Error al guardar: " + error);
            }
        }

        async function eliminar(id) {
            if (confirm("¿Eliminar este vehículo?")) {
                const resp = await fetch(`/Admin/Eliminar?id=${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(resp.ok) listar();
            }
        }

        function editar(id, marca, modelo, anio, precio) {
            document.getElementById('vId').value = id;
            document.getElementById('vMarca').value = marca;
            document.getElementById('vModelo').value = modelo;
            document.getElementById('vAnio').value = anio;
            document.getElementById('vPrecio').value = precio;
            myModal.show();
        }
    </script>
} *@






