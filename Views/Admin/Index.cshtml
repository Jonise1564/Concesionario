@* 
@{
    ViewData["Title"] = "Panel de Control";
}

<style>
    /* Estructura Principal */
    .admin-container {
        display: flex;
        min-height: 100vh;
        background-color: #000;
        padding-top: 100px; 
        position: relative;
    }

    /* Barra Lateral */
    .sidebar {
        width: 250px;
        background-color: #0b0b0b;
        border-right: 1px solid #222;
        padding: 20px;
        position: fixed;
        top: 100px; 
        left: 0;
        bottom: 0;
        z-index: 999;
    }

    .main-content {
        margin-left: 250px; 
        width: calc(100% - 250px);
        padding: 30px;
    }

    .nav-admin-link {
        display: flex;
        align-items: center;
        padding: 12px 15px;
        color: #888;
        text-decoration: none;
        border-radius: 8px;
        margin-bottom: 10px;
        transition: 0.3s;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .nav-admin-link:hover, .nav-admin-link.active {
        background-color: #dc3545;
        color: white;
    }

    .nav-admin-link i { margin-right: 10px; font-size: 1.1rem; }
    .table-dark { background-color: #0b0b0b !important; }
    .fixed-top { z-index: 1030 !important; }

    /* Estilos del Preview de Imagen */
    .preview-container {
        border: 2px dashed #333;
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #050505;
        border-radius: 8px;
        overflow: hidden;
    }
    #imgPreview {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
</style>

<div class="admin-container">
    <aside class="sidebar">
        <p class="text-muted small fw-bold mb-4 px-2">MENÚ ADMINISTRADOR</p>
        <nav>
            <a href="#" class="nav-admin-link active"><i class="bi bi-car-front"></i> Vehículos</a>
            <a href="#" class="nav-admin-link"><i class="bi bi-people"></i> Usuarios</a>
            <a href="#" class="nav-admin-link"><i class="bi bi-envelope"></i> Mensajes</a>
            <a href="#" class="nav-admin-link"><i class="bi bi-gear"></i> Configuración</a>
            <hr class="border-secondary">
            <a href="/" class="nav-admin-link text-info"><i class="bi bi-arrow-left-circle"></i> Volver a la Web</a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-800 text-uppercase text-white">Gestión de <span class="text-danger">Stock</span></h2>
                <button class="btn btn-danger btn-sm px-4 fw-bold" onclick="abrirModal()">
                    <i class="bi bi-plus-lg"></i> NUEVO INGRESO
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-dark table-hover border-secondary align-middle">
                    <thead class="text-muted small">
                        <tr>
                            <th>MARCA</th>
                            <th>MODELO / VERSIÓN</th>
                            <th>AÑO</th>
                            <th>PRECIO</th>
                            <th>STOCK</th>
                            <th>ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody id="tablaCuerpo"></tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="modalVehiculo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title fw-bold text-white" id="modalTitulo">DATOS DEL VEHÍCULO</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-white">
                <form id="formVehiculo">
                    <input type="hidden" id="vId" value="0">
                    <div class="row">
                        <div class="col-md-8 border-end border-secondary">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Marca</label>
                                    <input type="text" id="vMarca" class="form-control bg-black border-secondary text-white" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Modelo</label>
                                    <input type="text" id="vModelo" class="form-control bg-black border-secondary text-white" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Versión</label>
                                    <input type="text" id="vVersion" class="form-control bg-black border-secondary text-white">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Año</label>
                                    <input type="number" id="vAnio" class="form-control bg-black border-secondary text-white" required>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Kilómetros</label>
                                    <input type="number" id="vKilometros" class="form-control bg-black border-secondary text-white" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Precio</label>
                                    <input type="number" id="vPrecio" class="form-control bg-black border-secondary text-white" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Stock</label>
                                    <input type="number" id="vStock" class="form-control bg-black border-secondary text-white" required value="1">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Categoría ID</label>
                                    <input type="number" id="vCategoriaId" class="form-control bg-black border-secondary text-white" required value="1">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Combustible</label>
                                    <select id="vCombustible" class="form-select bg-black border-secondary text-white">
                                        <option value="Nafta">Nafta</option>
                                        <option value="Diesel">Diesel</option>
                                        <option value="Híbrido">Híbrido</option>
                                        <option value="Eléctrico">Eléctrico</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-danger text-uppercase">Transmisión</label>
                                    <select id="vTransmision" class="form-select bg-black border-secondary text-white">
                                        <option value="Manual">Manual</option>
                                        <option value="Automática">Automática</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-danger text-uppercase">URL Imagen</label>
                                <input type="text" id="vImagenUrl" class="form-control bg-black border-secondary text-white" oninput="actualizarPreview()" placeholder="https://...">
                            </div>
                            <div class="preview-container mt-2">
                                <img id="imgPreview" src="" onerror="this.src='https://placehold.co/400x300/000000/FFFFFF?text=Sin+Imagen'">
                            </div>
                            <p class="text-center small text-muted mt-2">Vista previa de la unidad</p>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light btn-sm" data-bs-dismiss="modal">CANCELAR</button>
                <button type="button" class="btn btn-danger btn-sm px-4 fw-bold" onclick="guardar()">GUARDAR CAMBIOS</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const token = localStorage.getItem('jonel_token');
        const myModal = new bootstrap.Modal(document.getElementById('modalVehiculo'));

        document.addEventListener("DOMContentLoaded", () => {
            if (!token) window.location.href = '/Home/Acceso';
            listar();
        });

        function actualizarPreview() {
            const url = document.getElementById('vImagenUrl').value;
            document.getElementById('imgPreview').src = url;
        }

        async function listar() {
            try {
                const resp = await fetch('/Admin/GetVehiculos', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await resp.json();
                document.getElementById('tablaCuerpo').innerHTML = data.map(v => `
                    <tr class="align-middle">
                        <td class="fw-bold text-white">${v.marca}</td>
                        <td class="text-white">${v.modelo} <br><small class="text-muted">${v.version || ''}</small></td>
                        <td class="text-white">${v.anio}</td>
                        <td class="text-danger fw-bold">$ ${v.precio.toLocaleString()}</td>
                        <td class="text-white">${v.stock}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-light me-2" onclick='editar(${JSON.stringify(v)})'>
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="eliminar(${v.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (err) { console.error("Error al listar:", err); }
        }

        function abrirModal() {
            document.getElementById('modalTitulo').innerText = "NUEVO INGRESO DE VEHÍCULO";
            document.getElementById('formVehiculo').reset();
            document.getElementById('vId').value = "0";
            actualizarPreview();
            myModal.show();
        }

        function editar(v) {
            document.getElementById('modalTitulo').innerText = "MODIFICAR VEHÍCULO";
            document.getElementById('vId').value = v.id;
            document.getElementById('vMarca').value = v.marca;
            document.getElementById('vModelo').value = v.modelo;
            document.getElementById('vVersion').value = v.version;
            document.getElementById('vAnio').value = v.anio;
            document.getElementById('vKilometros').value = v.kilometros;
            document.getElementById('vPrecio').value = v.precio;
            document.getElementById('vStock').value = v.stock;
            document.getElementById('vCombustible').value = v.combustible;
            document.getElementById('vTransmision').value = v.transmision;
            document.getElementById('vCategoriaId').value = v.categoriaId;
            document.getElementById('vImagenUrl').value = v.imagenUrl;
            actualizarPreview();
            myModal.show();
        }

        async function guardar() {
            const model = {
                id: parseInt(document.getElementById('vId').value),
                marca: document.getElementById('vMarca').value,
                modelo: document.getElementById('vModelo').value,
                version: document.getElementById('vVersion').value,
                anio: parseInt(document.getElementById('vAnio').value),
                kilometros: parseInt(document.getElementById('vKilometros').value),
                precio: parseFloat(document.getElementById('vPrecio').value),
                stock: parseInt(document.getElementById('vStock').value),
                combustible: document.getElementById('vCombustible').value,
                transmision: document.getElementById('vTransmision').value,
                categoriaId: parseInt(document.getElementById('vCategoriaId').value),
                imagenUrl: document.getElementById('vImagenUrl').value || "default.jpg"
            };

            const response = await fetch('/Admin/Guardar', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json', 
                    'Authorization': `Bearer ${token}` 
                },
                body: JSON.stringify(model)
            });

            if (response.ok) {
                myModal.hide();
                listar();
            } else {
                alert("Error al guardar los datos.");
            }
        }

        async function eliminar(id) {
            if (confirm("¿Eliminar este vehículo?")) {
                const resp = await fetch(`/Admin/Eliminar?id=${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(resp.ok) listar();
            }
        }
    </script>
} *@

