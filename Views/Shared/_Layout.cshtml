<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="headerNav">
        @* <nav class="navbar navbar-expand-sm navbar-dark navbar-custom position-absolute w-100 py-3"> *@
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom fixed-top w-100 py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/cars/jonel2.png" alt="Jonel Autos" class="logo">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Vehiculos" asp-action="Index">Vehículos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Financiamiento">Financiamiento</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="SobreNosotros">Sobre Nosotros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Contacto">Contacto</a>
                        </li>

                        <li class="nav-item" id="menuAcceso">
                            <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Acceso">Acceso</a>
                        </li>
                        
                        <li class="nav-item" id="menuAdmin" style="display:none;">
                            <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Index">Panel Admin</a>
                        </li>

                        <li class="nav-item" id="menuLogout" style="display:none;">
                            <a class="nav-link text-dark" href="javascript:void(0)" onclick="cerrarSesion()">
                                <i class="bi bi-box-arrow-right"></i> Salir
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container text-center">
            <h5 class="footer-title">Jonel Automotores</h5>
            <p class="footer-text">Calidad, confianza y los mejores vehículos del mercado.</p>
            <hr class="footer-line">
            <p class="footer-copy">© 2026 Jonel Automotores - Todos los derechos reservados</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const token = localStorage.getItem('jonel_token');
            const menuAcceso = document.getElementById('menuAcceso');
            const menuAdmin = document.getElementById('menuAdmin');
            const menuLogout = document.getElementById('menuLogout');

            if (token) {
                // Si hay token, ocultamos "Acceso" y mostramos "Panel Admin" y "Salir"
                if(menuAcceso) menuAcceso.style.display = 'none';
                if(menuAdmin) menuAdmin.style.display = 'block';
                if(menuLogout) menuLogout.style.display = 'block';
            }
        });

        function cerrarSesion() {
            localStorage.removeItem('jonel_token');
            localStorage.removeItem('jonel_user');
            window.location.href = '/Home/Index';
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div id="chat-bubble">💬</div>

    <div id="chat-box">
        <div id="chat-messages"></div>
        <input type="text" id="chat-input" placeholder="Escribí tu consulta..." />
    </div>

    <style>
        /* BOTÓN FLOTANTE */
        #chat-bubble {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #eb0a1e;
            color: white;
            padding: 15px;
            border-radius: 50%;
            cursor: pointer;
            z-index: 9999;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        }

        /* CONTENEDOR DEL CHAT */
        #chat-box {
            position: fixed;
            bottom: 80px;
            right: 20px;
            width: 340px;
            height: 550px;
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 10px;
            display: none;
            flex-direction: column;
            overflow: hidden;
            z-index: 9999;
        }

        /* MENSAJES */
        #chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            color: white;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        /* MENSAJE BOT */
        .mensaje-bot {
            background: #2a2a2a;
            padding: 10px;
            border-radius: 10px;
            font-size: 14px;
            max-width: 80%;
            align-self: flex-start;
            white-space: pre-line; /* 🔥 clave para los saltos */
        }

        /* MENSAJE USER */
        .mensaje-user {
            background: #eb0a1e;
            padding: 10px;
            border-radius: 10px;
            font-size: 14px;
            max-width: 80%;
            align-self: flex-end;
            text-align: right;
        }

        /* INPUT */
        #chat-input {
            border: none;
            padding: 12px;
            outline: none;
            width: 100%;
            background: #2a2a2a;
            color: white;
        }
    </style>

    <script>
        const bubble = document.getElementById("chat-bubble");
        const box = document.getElementById("chat-box");
        const input = document.getElementById("chat-input");
        const messages = document.getElementById("chat-messages");

        bubble.onclick = () => {
            box.style.display = box.style.display === "flex" ? "none" : "flex";
        };

        function formatearPrecio(texto) {
            return texto.replace(/\$([0-9]+)/g, (match, num) => {
                return "$" + Number(num).toLocaleString("es-AR");
            });
        }    

        input.addEventListener("keypress", async (e) => {
            if (e.key === "Enter") {
                const text = input.value;
                input.value = "";
                messages.innerHTML += `<div class="mensaje-user">${text}</div>`;

                const res = await fetch("/api/chat", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ message: text })
                });

                const data = await res.json();

                const textoFormateado = formatearPrecio(data.reply);

                messages.innerHTML += `<div class="mensaje-bot">${textoFormateado.replace(/\n/g, "<br>")}</div>`;
                messages.scrollTop = messages.scrollHeight;
            }
        });
    </script>

</body>
</html>