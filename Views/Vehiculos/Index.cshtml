@model IEnumerable<Concesionario.Models.Vehiculo>

<div class="container mt-5">
    @* --- Cabecera --- *@
    <div class="mb-4">
        <h2 class="text-uppercase fw-900 m-0">Vehículos</h2>
        <div style="width: 50px; border: 2px solid #eb0a1e; margin-top: 10px;"></div>
    </div>

    @* --- Panel de Filtros --- *@
    <div class="card border-0 shadow-sm mb-5 p-4 bg-light">
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <label class="form-label small fw-bold text-uppercase">Búsqueda rápida</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-danger"></i></span>
                    <input type="text" id="buscadorVehiculos" class="form-control border-start-0 ps-0" placeholder="Marca, modelo...">
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label small fw-bold text-uppercase">Kilómetros (Desde - Hasta)</label>
                <div class="d-flex gap-2">
                    <input type="number" id="kmDesde" class="form-control" placeholder="Min">
                    <input type="number" id="kmHasta" class="form-control" placeholder="Max">
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label small fw-bold text-uppercase">Precio Máximo (USD/ARS)</label>
                <input type="range" class="form-range" id="precioMax" min="0" max="100000000" step="500000">
                <div class="d-flex justify-content-between">
                    <span class="small text-muted">$0</span>
                    <span id="labelPrecio" class="small fw-bold text-danger">Cualquier precio</span>
                </div>
            </div>
        </div>
    </div>

    @* --- Mensaje cuando no hay resultados --- *@
    <div id="mensajeVacio" class="text-center py-5 d-none">
        <i class="bi bi-exclamation-circle text-muted display-4"></i>
        <h4 class="text-muted mt-3">No encontramos vehículos que coincidan con los filtros.</h4>
        <button class="btn btn-outline-danger btn-sm mt-2" onclick="location.reload()">Limpiar Filtros</button>
    </div>

    @* --- Grid de Vehículos --- *@
    <div class="row" id="gridVehiculos">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4 mb-4 tarjeta-vehiculo" 
                 data-marca="@item.Marca?.ToLower()"
                 data-modelo="@item.Modelo.ToLower()" 
                 data-version="@item.Version?.ToLower()"
                 data-precio="@item.Precio"
                 data-km="@item.Kilometros">
                
                <div class="card h-100 shadow-sm border-0 transition-hover overflow-hidden">
                    <div class="position-relative img-container">
                        @{
                            // CAMBIO AQUÍ: Usamos .jpeg y agregamos un parámetro de versión para limpiar la caché
                            var nombreArchivo = string.IsNullOrEmpty(item.ImagenUrl) ? (item.Modelo + ".jpeg") : item.ImagenUrl;
                            var rutaFinal = "/img/cars/" + nombreArchivo + "?v=" + DateTime.Now.Ticks;
                        }
                        <img src="@rutaFinal" 
                             class="card-img-top img-fluid" 
                             alt="@item.Modelo"
                             loading="lazy"
                             onerror="this.onerror=null;this.src='/img/cars/toyota-placeholder.jpeg';">
                        
                        <div class="badge-status-container">
                            <span class="badge-status @(item.Kilometros == 0 ? "bg-success" : "bg-dark")">
                                @(item.Kilometros == 0 ? "NUEVO 0KM" : "USADO SELECCIONADO")
                            </span>
                        </div>
                    </div>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-muted fw-bold text-uppercase" style="font-size: 0.75rem;">@item.Marca</small>
                            <span class="fw-bold text-danger">@item.Anio</span>
                        </div>
                        
                        <h4 class="card-title text-uppercase fw-900 mb-1">@item.Modelo</h4>
                        <p class="text-muted small mb-3 text-truncate">@item.Version | @item.Transmision</p>

                        <div class="d-flex gap-3 mb-4">
                            <div class="info-tag">
                                <i class="bi bi-speedometer2 text-danger"></i>
                                <span>@item.Kilometros.ToString("N0") KM</span>
                            </div>
                            <div class="info-tag">
                                <i class="bi bi-fuel-pump text-danger"></i>
                                <span>@item.Combustible</span>
                            </div>
                        </div>
                        
                        <div class="mt-auto pt-3 border-top">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block text-uppercase" style="font-size: 0.65rem;">Precio sugerido</small>
                                    <span class="h4 mb-0 fw-900">@item.Precio.ToString("C0")</span>
                                </div>
                                <a href="#" class="btn btn-dark btn-sm px-3 fw-bold rounded-0">VER MÁS</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .fw-900 { font-weight: 900; }
    .transition-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .transition-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    
    .img-container { width: 100%; aspect-ratio: 16 / 9; background-color: #f8f9fa; overflow: hidden; }
    .img-container img { width: 100%; height: 100%; object-fit: cover; }

    .badge-status-container { position: absolute; top: 15px; left: 15px; z-index: 2; }
    .badge-status { color: white; padding: 5px 12px; font-size: 0.65rem; font-weight: 800; letter-spacing: 1px; border-radius: 2px; }

    .info-tag { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 600; color: #444; }
    .form-range::-webkit-slider-thumb { background: #eb0a1e; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const buscador = document.getElementById('buscadorVehiculos');
            const kmDesde = document.getElementById('kmDesde');
            const kmHasta = document.getElementById('kmHasta');
            const precioMax = document.getElementById('precioMax');
            const labelPrecio = document.getElementById('labelPrecio');
            const tarjetas = document.querySelectorAll('.tarjeta-vehiculo');
            const mensajeVacio = document.getElementById('mensajeVacio');

            let maxPrecioEncontrado = 0;
            tarjetas.forEach(t => {
                const p = parseFloat(t.getAttribute('data-precio'));
                if (p > maxPrecioEncontrado) maxPrecioEncontrado = p;
            });
            precioMax.max = maxPrecioEncontrado;
            precioMax.value = maxPrecioEncontrado;

            function filtrar() {
                const query = buscador.value.toLowerCase().trim();
                const minKm = parseInt(kmDesde.value) || 0;
                const maxKm = parseInt(kmHasta.value) || Infinity;
                const maxPrecio = parseFloat(precioMax.value);

                labelPrecio.innerText = "Hasta $" + maxPrecio.toLocaleString();

                let visibles = 0;

                tarjetas.forEach(tarjeta => {
                    const marca = tarjeta.getAttribute('data-marca') || "";
                    const modelo = tarjeta.getAttribute('data-modelo') || "";
                    const version = tarjeta.getAttribute('data-version') || "";
                    const precio = parseFloat(tarjeta.getAttribute('data-precio'));
                    const km = parseInt(tarjeta.getAttribute('data-km'));

                    const coincideTexto = marca.includes(query) || modelo.includes(query) || version.includes(query);
                    const coincideKm = km >= minKm && km <= maxKm;
                    const coincidePrecio = precio <= maxPrecio;

                    if (coincideTexto && coincideKm && coincidePrecio) {
                        tarjeta.style.display = "block";
                        visibles++;
                    } else {
                        tarjeta.style.display = "none";
                    }
                });

                mensajeVacio.classList.toggle('d-none', visibles > 0);
            }

            buscador.addEventListener('input', filtrar);
            kmDesde.addEventListener('input', filtrar);
            kmHasta.addEventListener('input', filtrar);
            precioMax.addEventListener('input', filtrar);
        });
    </script>
}