@model IEnumerable<Concesionario.Models.Vehiculo>

@{
    ViewData["Title"] = "Stock de Vehículos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <style>
        /* Estilos Base Modo Oscuro */
        body { background-color: #121212; color: #e0e0e0; margin-top: 6rem; }

        .fw-900 { font-weight: 900; }
        .text-danger { color: #eb0a1e !important; }

        /* Cabecera */
        .titulo-seccion { color: #ffffff; border-left: 5px solid #eb0a1e; padding-left: 15px; }

        /* Panel de Filtros Dark */
        .filtro-dark {
            background-color: #1e1e1e !important;
            border: 1px solid #333 !important;
            color: #fff;
        }
        
        /* Estilo para que las letras de los labels sean blancas */
        .filtro-dark label {
            color: #ffffff !important;
            opacity: 0.9;
            margin-bottom: 0.5rem;
        }

        .filtro-dark .form-control, .filtro-dark .input-group-text {
            background-color: #2a2a2a;
            border-color: #444;
            color: #fff !important; /* Texto que escribe el usuario en blanco */
        }

        .filtro-dark .form-control::placeholder {
            color: #777 !important;
        }

        .filtro-dark .form-control:focus {
            background-color: #333;
            border-color: #eb0a1e;
            color: #fff;
            box-shadow: none;
        }

        /* Tarjetas Dark */
        .tarjeta-dark {
            background-color: #1e1e1e !important;
            border: 1px solid #2a2a2a !important;
            transition: all 0.3s ease;
        }
        .tarjeta-dark:hover {
            transform: translateY(-8px);
            border-color: #eb0a1e !important;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5) !important;
        }

        .img-container { 
            width: 100%; 
            aspect-ratio: 16 / 9; 
            background-color: #2a2a2a; 
            overflow: hidden; 
        }
        .img-container img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
        .tarjeta-dark:hover img { opacity: 1; }

        .info-tag { 
            display: flex; 
            align-items: center; 
            gap: 6px; 
            font-size: 0.85rem; 
            font-weight: 600; 
            color: #bbb; 
        }

        .border-top-dark { border-top: 1px solid #333 !important; }

        /* Botones y Badges */
        .btn-red {
            background-color: #eb0a1e;
            color: white;
            border-radius: 0;
            font-weight: bold;
            transition: 0.3s;
            border: none;
        }
        .btn-red:hover { background-color: #c40819; color: white; }
        
        .badge-status { 
            position: absolute; top: 15px; left: 15px; 
            color: white; padding: 5px 12px; font-size: 0.65rem; 
            font-weight: 800; letter-spacing: 1px; border-radius: 2px; z-index: 2;
        }

        /* Range Slider Custom */
        .form-range::-webkit-slider-thumb { background: #eb0a1e; }
        .form-range::-moz-range-thumb { background: #eb0a1e; }
    </style>
}

<div class="container mt-5 pt-4 mainDiv">
    @* --- Cabecera --- *@
    <div class="mb-5">
        <h2 class="text-uppercase fw-900 m-0 titulo-seccion"></h2>
    </div>

    @* --- Panel de Filtros --- *@
    <div class="card filtro-dark shadow-sm mb-5 p-4">
        <div class="row g-5">
            <div class="col-12 col-md-6">
                <label class="form-label small fw-bold text-uppercase">Búsqueda rápida</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search text-danger"></i></span>
                    <input type="text" id="buscadorVehiculos" class="form-control" placeholder="Ej: Toyota, Hilux, Automático...">
                </div>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label small fw-bold text-uppercase">Kilometraje</label>
                <div class="d-flex gap-2">
                    <input type="number" id="kmDesde" class="form-control" placeholder="Mín">
                    <input type="number" id="kmHasta" class="form-control" placeholder="Máx">
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="d-flex justify-content-between">
                    <label class="form-label small fw-bold text-uppercase">Precio Máximo</label>
                    <span id="labelPrecio" class="small fw-bold text-danger">Cualquier precio</span>
                </div>
                <input type="range" class="form-range" id="precioMax" min="0" max="1000000" step="1000">
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label small fw-bold text-uppercase">Ordenar por</label>
                <select id="ordenar" class="form-control">
                    <option value="default">Por defecto</option>
                    <option value="precio-asc">Precio: menor a mayor</option>
                    <option value="precio-desc">Precio: mayor a menor</option>
                    <option value="anio-desc">Año: más nuevo</option>
                    <option value="anio-asc">Año: más viejo</option>
                    <option value="km-asc">Menos km</option>
                    <option value="km-desc">Más km</option>
                </select>
            </div> 
        </div>
    </div>

    @* --- Grid de Vehículos --- *@
    <div class="row" id="gridVehiculos">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4 mb-4 tarjeta-vehiculo" 
                 data-marca="@item.Marca?.ToLower()"
                 data-modelo="@item.Modelo.ToLower()" 
                 data-precio="@item.Precio"
                 data-km="@item.Kilometros"
                 data-anio="@item.Anio">
                 
                
                <div class="card h-100 tarjeta-dark overflow-hidden">
                    <div class="position-relative img-container">
                        @{
                            var nombreArchivo = string.IsNullOrEmpty(item.ImagenUrl) ? (item.Modelo + ".jpeg") : item.ImagenUrl;
                            var rutaFinal = "/img/cars/" + nombreArchivo + "?v=" + DateTime.Now.Ticks;
                        }
                        <img src="@rutaFinal" alt="@item.Modelo" loading="lazy"
                             onerror="this.onerror=null;this.src='/img/cars/placeholder-dark.jpeg';">
                        
                        <span class="badge-status @(item.Kilometros == 0 ? "bg-success" : "bg-danger")">
                            @(item.Kilometros == 0 ? "NUEVO 0KM" : "USADO SELECCIONADO")
                        </span>
                    </div>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-danger fw-bold text-uppercase" style="letter-spacing: 1px;">@item.Marca</small>
                            <span class="fw-bold text-white">@item.Anio</span>
                        </div>
                        
                        <h4 class="text-uppercase fw-900 mb-1 text-white">@item.Modelo</h4>
                        <p class="text-muted small mb-3">@item.Version | @item.Transmision</p>

                        <div class="d-flex gap-3 mb-4">
                            <div class="info-tag">
                                <i class="bi bi-speedometer2 text-danger"></i>
                                <span>@item.Kilometros.ToString("N0") KM</span>
                            </div>
                            <div class="info-tag">
                                <i class="bi bi-fuel-pump text-danger"></i>
                                <span>@item.Combustible</span>
                            </div>
                        </div>
                        
                        <div class="mt-auto pt-3 border-top-dark">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem;">Precio Sugerido</small>
                                    <span class="h4 mb-0 fw-900 text-white">@item.Precio.ToString("C0")</span>
                                </div>
                                <a href="#" class="btn btn-red btn-sm px-3">DETALLES</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const buscador = document.getElementById('buscadorVehiculos');
            const kmDesde = document.getElementById('kmDesde');
            const kmHasta = document.getElementById('kmHasta');
            const precioMax = document.getElementById('precioMax');
            const labelPrecio = document.getElementById('labelPrecio');
            const tarjetas = document.querySelectorAll('.tarjeta-vehiculo');
            const ordenar = document.getElementById('ordenar');
            const grid = document.getElementById('gridVehiculos');

            // Ajuste dinámico del rango de precio
            let maxPrecioEncontrado = 0;
            tarjetas.forEach(t => {
                const p = parseFloat(t.getAttribute('data-precio'));
                if (p > maxPrecioEncontrado) maxPrecioEncontrado = p;
            });
            precioMax.max = maxPrecioEncontrado;
            precioMax.value = maxPrecioEncontrado;

            function filtrar() {
                const query = buscador.value.toLowerCase().trim();
                const minKm = parseInt(kmDesde.value) || 0;
                const maxKm = parseInt(kmHasta.value) || Infinity;
                const maxPrecio = parseFloat(precioMax.value);

                labelPrecio.innerText = "Hasta $" + maxPrecio.toLocaleString();

                tarjetas.forEach(tarjeta => {
                    const marca = tarjeta.getAttribute('data-marca') || "";
                    const modelo = tarjeta.getAttribute('data-modelo') || "";
                    const precio = parseFloat(tarjeta.getAttribute('data-precio'));
                    const km = parseInt(tarjeta.getAttribute('data-km'));

                    const coincideTexto = marca.includes(query) || modelo.includes(query);
                    const coincideKm = km >= minKm && km <= maxKm;
                    const coincidePrecio = precio <= maxPrecio;

                    tarjeta.style.display = (coincideTexto && coincideKm && coincidePrecio) ? "block" : "none";
                });
            }

            function ordenarTarjetas() {
                const tipo = ordenar.value;
                const tarjetasArray = Array.from(tarjetas);

                tarjetasArray.sort((a, b) => {
                    const precioA = parseFloat(a.dataset.precio);
                    const precioB = parseFloat(b.dataset.precio);
                    const kmA = parseInt(a.dataset.km);
                    const kmB = parseInt(b.dataset.km);
                    const anioA = parseInt(a.dataset.anio);
                    const anioB = parseInt(b.dataset.anio);

                    switch (tipo) {
                        case "precio-asc": return precioA - precioB;
                        case "precio-desc": return precioB - precioA;
                        case "anio-desc": return anioB - anioA;
                        case "anio-asc": return anioA - anioB;
                        case "km-asc": return kmA - kmB;
                        case "km-desc": return kmB - kmA;
                        default: return 0;
                    }
                });

                tarjetasArray.forEach(t => grid.appendChild(t));
            }

            buscador.addEventListener('input', filtrar);
            kmDesde.addEventListener('input', filtrar);
            kmHasta.addEventListener('input', filtrar);
            precioMax.addEventListener('input', filtrar);
            ordenar.addEventListener('change', ordenarTarjetas);
            filtrar();
            ordenarTarjetas();
        });
    </script>
}